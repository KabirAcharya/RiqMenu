# Auto detect text files and normalize line endings to LF in the repo
* text=auto eol=lf

# Ensure these are always LF
*.cs text eol=lf
*.csproj text eol=lf
*.sln text eol=lf
*.md text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf
*.editorconfig text eol=lf

# Binary files
*.png binary
*.jpg binary
*.gif binary
*.dll binary
*.exe binary
